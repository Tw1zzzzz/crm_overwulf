{
  "manifest_version": 1,
  "type": "WebApp",
  "meta": {
    "name": "CRM Atlant Desktop",
    "author": "CRM Atlant",
    "version": "0.1.0",
    "minimum-overwolf-version": "0.296.0.0",
    "description": "Desktop Overwolf client for pre-match, session and post-match player analytics.",
    "dock_button_title": "CRM Atlant",
    "icon": "favicon.ico",
    "icon_gray": "favicon.ico",
    "launcher_icon": "favicon.ico",
    "window_icon": "favicon.ico"
  },
  "permissions": [
    "GameInfo",
    "Hotkeys",
    "profile"
  ],
  "data": {
    "game_targeting": {
      "type": "all"
    },
    "start_window": "desktop",
    "hotkeys": {
      "toggle_notes": {
        "title": "Show notes",
        "action-type": "custom",
        "default": "Ctrl+Shift+N",
        "passthrough": true
      },
      "new_note": {
        "title": "New note",
        "action-type": "custom",
        "default": "Ctrl+Shift+M",
        "passthrough": true
      }
    },
    "externally_connectable": {
      "matches": [
        "https://www.overwolf.com",
        "https://*.overwolf.com"
      ]
    },
    "windows": {
      "desktop": {
        "file": "index.html",
        "desktop_only": true,
        "in_game_only": false,
        "transparent": false,
        "resizable": true,
        "show_in_taskbar": true,
        "show_minimize": true,
        "show_maximize": true,
        "use_os_windowing": true,
        "native_window": true,
        "size": {
          "width": 1280,
          "height": 820
        },
        "min_size": {
          "width": 960,
          "height": 640
        }
      },
      "post_match": {
        "file": "index.html",
        "desktop_only": false,
        "in_game_only": false,
        "transparent": false,
        "resizable": true,
        "show_in_taskbar": false,
        "show_minimize": true,
        "show_maximize": false,
        "use_os_windowing": true,
        "native_window": true,
        "size": {
          "width": 920,
          "height": 680
        },
        "min_size": {
          "width": 760,
          "height": 560
        }
      },
      "notes_overlay": {
        "file": "index.html",
        "desktop_only": false,
        "in_game_only": true,
        "transparent": true,
        "resizable": true,
        "show_in_taskbar": false,
        "show_minimize": false,
        "show_maximize": false,
        "grab_keyboard_focus": true,
        "clickthrough": false,
        "topmost": true,
        "keep_window_location": true,
        "size": {
          "width": 900,
          "height": 620
        },
        "min_size": {
          "width": 520,
          "height": 360
        }
      }
    }
  }
}
