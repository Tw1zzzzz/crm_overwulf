# Основные настройки приложения
PORT=5001
NODE_ENV=development
JWT_SECRET=replace_with_long_random_secret

# MongoDB подключение
MONGODB_URI=mongodb://localhost:27017/esports-mood-tracker

# FACEIT API и OAuth настройки
FACEIT_API_KEY=your_faceit_api_key
FACEIT_CLIENT_ID=your_faceit_client_id
FACEIT_CLIENT_SECRET=your_faceit_client_secret
REDIRECT_URI=http://localhost:5001/api/faceit/oauth/callback
STAFF_PRIVILEGE_KEY=replace_with_staff_key

# Почта. Для локального запуска можно оставить пустыми, если письма не нужны.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@example.com
MAIL_PASS=your_email_app_password
MAIL_FROM="PerformanceCoach <your_email@example.com>"
CLIENT_URL=http://localhost:8080

# Robokassa
ROBOKASSA_LOGIN=your_merchant_login
ROBOKASSA_PASS1=your_password_1
ROBOKASSA_PASS2=your_password_2
ROBOKASSA_HASH_ALGORITHM=md5
ROBOKASSA_TEST_MODE=true

# Другие настройки
LOG_LEVEL=debug
